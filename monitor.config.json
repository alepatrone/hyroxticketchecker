{
  "events": [
    {
      "key": "tenerife",
      "name": "HYROX Tenerife | Season 26/27",
      "officialEventPageUrl": "https://hyrox.com/event/hyrox-tenerife/"
    }
  ],
  "monitoring": {
    "mode": "checkout_page_availability_json",
    "userAgent": "Mozilla/5.0 hyrox-ticket-monitor/1.0",
    "timeoutSeconds": 30,
    "retryAttempts": 3,
    "retryDelaySeconds": 10,
    "minimumMinutesBetweenChecks": 15,
    "alertOnlyOnChanges": true,
    "alertOnFirstRunAvailableTickets": true,
    "stateFile": "monitor.state.json",
    "logFile": "monitor.log"
  },
  "ticketFilter": {
    "onlyAthleteTickets": true,
    "excludedCompetitionClasses": [],
    "competitionMetaField": "meta.is_competition",
    "competitionMetaValue": "TRUE",
    "availableWhen": {
      "field": "buyable",
      "equals": true
    },
    "ignoreNamesContaining": [
      "CHARITY",
      "ADAPTIVE",
      "SPECTATOR",
      "PHOTO PACKAGE",
      "FREE U12"
    ],
    "prioritySignals": [
      {
        "label": "Open Men",
        "competitionClass": "SOLO_OPEN_M",
        "nameMustNotContain": [
          "CHARITY"
        ],
      "priorityMessagePrefix": "PRIORITY: Open Men ticket available"
      }
    ]
  },
  "scheduleRecommendation": {
    "normal": {
      "description": "Low-noise baseline checks.",
      "timesLocal": [
        "08:00",
        "20:00"
      ]
    },
    "highInterest": {
      "description": "Use this when you are actively trying to catch returned tickets.",
      "intervalMinutes": 45,
      "activeHoursLocal": {
        "start": "07:00",
        "end": "23:00"
      }
    }
  },
  "notifications": {
    "telegram": {
      "enabled": true,
      "botTokenEnvVar": "TELEGRAM_BOT_TOKEN",
      "chatIdEnvVar": "TELEGRAM_CHAT_ID",
      "notifyOn": [
        "new_active_athlete_ticket",
        "ticket_became_active",
        "priority_ticket_became_active",
        "ticket_page_temporarily_unreadable",
        "monitor_error_after_retries"
      ]
    }
  }
}
